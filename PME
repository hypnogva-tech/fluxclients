  <style>
    :root {
      --navy: #0f1b35; --navy2: #1e3a5f; --green: #22c55e;
      --muted: #64748b; --muted2: #94a3b8; --line: #f1f5f9; --line2: #e2e8f0; --bg: #f8fafc;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: #ffffff; color: var(--navy); }

    .dot { width: 8px; height: 8px; background: var(--green); border-radius: 50%; }
    .audience { display: flex; width: fit-content; align-items: center; gap: 8px; background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.4); color: var(--navy); font-weight: 700; font-size: 13px; padding: 7px 15px; border-radius: 100px; margin: 0 auto 18px; }

    .wrap { max-width: 1080px; margin: 0 auto; padding: 14px 20px 48px; display: grid; grid-template-columns: 1fr; gap: 18px; }

    .section-title { font-size: 20px; font-weight: 800; letter-spacing: -0.5px; color: var(--navy); margin-bottom: 18px; }

    /* HERO */
    .hero h1 { font-size: clamp(28px, 4.5vw, 42px); font-weight: 900; line-height: 1.12; letter-spacing: -1px; margin-bottom: 16px; text-align: center; }
    .hero h1 .hl { background: var(--navy); color: #fff; padding: 2px 10px; border-radius: 6px; display: inline; }
    .hero .sub { font-size: clamp(15px, 2vw, 17px); color: var(--muted); line-height: 1.65; max-width: 540px; margin: 0 auto; text-align: center; }

    /* CHECKS */
    .checks { display: flex; flex-direction: column; gap: 10px; }
    .check { display: flex; align-items: flex-start; gap: 10px; font-size: 15px; color: var(--navy); }
    .check-icon { color: var(--green); font-size: 16px; flex-shrink: 0; margin-top: 1px; }

    /* LOGOS */
    .logos-row { display: flex; align-items: center; justify-content: center; gap: 36px; flex-wrap: wrap; }
    .logos-row img { width: auto; } .logos-row .logo-lm { background: #0f1b35; padding: 8px 14px; border-radius: 8px; }
    .logos-row .logo-rosh { height: 32px; }
    .logos-row .logo-lm { height: 56px; }

    /* TESTIMONIAL */
    .testimonial { background: var(--bg); border: 1px solid var(--line2); border-radius: 16px; padding: 22px 24px; }
    .testimonial .stars { color: #f5b301; font-size: 15px; letter-spacing: 2px; margin-bottom: 10px; }
    .testimonial .quote { font-size: 15.5px; line-height: 1.6; color: var(--navy); font-style: italic; margin-bottom: 14px; }
    .testimonial .author { font-size: 13px; font-weight: 700; color: var(--navy); }
    .testimonial .author span { color: var(--muted); font-weight: 500; }
    .t-result { display: flex; align-items: center; gap: 14px; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--line2); }
    .t-result-num { font-size: 28px; font-weight: 800; letter-spacing: -1px; color: var(--green); line-height: 1; flex-shrink: 0; }
    .t-result-label { font-size: 12.5px; color: var(--muted); line-height: 1.4; }

    /* STICKY CTA */
    .sticky-cta { display: none; }

    /* BOOKING */
    .cal-card { border: 1px solid var(--line2); border-radius: 16px; overflow: hidden; box-shadow: 0 6px 28px rgba(15,27,53,0.07); background: #fff; }
    .calendly-inline-widget { min-width: 300px; height: 720px; }
    #rdv { scroll-margin-top: 16px; }

    /* HOW IT WORKS */
    .steps { display: flex; flex-direction: column; gap: 0; position: relative; }
    .steps .line { position: absolute; left: 19px; top: 40px; bottom: 40px; width: 2px; background: var(--line2); }
    .step { display: flex; gap: 20px; padding-bottom: 24px; position: relative; }
    .step:last-child { padding-bottom: 0; }
    .step .num { width: 40px; height: 40px; background: var(--navy); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 15px; flex-shrink: 0; z-index: 1; }
    .step .body { padding-top: 8px; }
    .step .body strong { font-size: 15px; }
    .step .body p { font-size: 13px; color: var(--muted); line-height: 1.6; margin-top: 4px; }

    /* FOUNDER */
    .founder { padding-top: 28px; border-top: 1px solid var(--line); }
    .founder p.bio { font-size: 14px; color: var(--navy); line-height: 1.7; margin-bottom: 12px; }
    .founder p.name { font-size: 14px; font-weight: 700; color: var(--navy); }

    footer { padding: 24px 20px; text-align: center; border-top: 1px solid var(--line); margin-top: 8px; }
    footer p { font-size: 12px; color: var(--muted2); }
    footer a { color: var(--muted); text-decoration: underline; }

    /* DESKTOP */
    @media (min-width: 900px) {
      .wrap { grid-template-columns: 1.05fr 0.95fr; gap: 28px 48px; align-items: start; padding-top: 20px; }
      .hero        { grid-column: 1; grid-row: 1; }
      .checks      { grid-column: 1; grid-row: 2; }
      .logos       { grid-column: 1; grid-row: 3; }
      .testimonial { grid-column: 1; grid-row: 4; }
      .how         { grid-column: 1; grid-row: 5; }
      .founder     { grid-column: 1; grid-row: 6; }
      .booking { grid-column: 2; grid-row: 1 / span 6; position: sticky; top: 16px; }
      .audience { font-size: 14.5px; padding: 8px 18px; }
      .section-title { font-size: 22px; }
      .logos-row { gap: 48px; }
      .logos-row .logo-rosh { height: 40px; }
      .logos-row .logo-lm { height: 64px; }
      .logos { border-top: 1px solid var(--line); padding-top: 28px; }
      .how   { border-top: 1px solid var(--line); padding-top: 28px; }
    }

    @media (max-width: 899px) {
      .sticky-cta { display: flex; align-items: center; justify-content: center; gap: 8px;
        position: fixed; left: 12px; right: 12px; bottom: 12px; z-index: 60;
        background: var(--navy); color: #fff; font-size: 16px; font-weight: 700;
        padding: 16px; border-radius: 12px; text-decoration: none;
        box-shadow: 0 8px 24px rgba(15,27,53,0.28);
        transform: translateY(160%); transition: transform .28s ease; }
      .sticky-cta.show { transform: translateY(0); }
    }
  </style>
</head>
<body>

  <div class="wrap">

    <!-- HERO -->
    <div class="hero">
      <div class="audience"><span class="dot"></span> Pour les dirigeants de PME 🇨🇭 · +300k CHF/an</div>
      <h1>
        Générez un flux continu de prospects qualifiés<br>pour votre PME 🇨🇭<br>
